# ============================================================
# Ahu_Plus .gitignore — 开源版
# ============================================================

# ── Android build ──────────────────────────────────────────
*.iml
.gradle
.kotlin/
/local.properties
/.idea/caches
/.idea/libraries
/.idea/modules.xml
/.idea/workspace.xml
/.idea/navEditor.xml
/.idea/assetWizardSettings.xml
.DS_Store
/build
app/build/
/captures
.externalNativeBuild
.cxx
local.properties

# ── 密钥与凭据 ────────────────────────────────────────────
.env
.env.*
*.jks
*.keystore
*.p12
*.pem
cos_config.properties
app/src/main/assets/cos_config.properties

# ── 本地技术文档（不上传）────────────────────────────────
docs/
AGENTS.md
BETA_TESTING.md
BUG_REVIEW.md
CLAUDE.md
SECURITY.md
.obsidian/
.understand-anything/
.claude/

# ── 开发工具脚本（不上传）────────────────────────────────
# tools/exam_prediction/ 例外 — 公开的排考预测工具
tools/
!tools/exam_prediction/

# ── 备份与调试产物 ────────────────────────────────────────
*.log
*.py[cod]
__pycache__/
*.apk
*.aab
version.json.v*
/release-snapshots/
/downloads/
/beta_release/
*.html
*.csv
!tools/exam_prediction/output_*.csv

# ── 截图与导出 ────────────────────────────────────────────
*.png
tools/_cap*.png
