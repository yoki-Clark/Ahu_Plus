# ============================================================
# Ahu_Plus .gitignore — 开源版
# ============================================================

# ── Android build ──────────────────────────────────────────
*.iml
.gradle
.kotlin/
/local.properties
/.idea/caches
/.idea/libraries
/.idea/modules.xml
/.idea/workspace.xml
/.idea/navEditor.xml
/.idea/assetWizardSettings.xml
.DS_Store
/build
app/build/
/captures
.externalNativeBuild
.cxx
local.properties

# ── 密钥与凭据 ────────────────────────────────────────────
.env
.env.*
*.jks
*.keystore
*.p12
*.pem
.jwt_token
*.jwt_token
cos_config.properties
app/src/main/assets/cos_config.properties

# ── 本地技术文档（不上传）────────────────────────────────
docs/
AGENTS.md
BETA_TESTING.md
BUG_REVIEW.md
CLAUDE.md
SECURITY.md
.obsidian/
.understand-anything/
.claude/

# ── 开发工具脚本（不上传）────────────────────────────────
# 例外 — 公开发布的工具：排考预测 + 集市 Token 获取工具
tools/*
!tools/exam_prediction/
!tools/集市Token获取工具/

# ── 备份与调试产物 ────────────────────────────────────────
*.log
*.py[cod]
__pycache__/
*.apk
*.aab
version.json.v*
# 排考预测:每日断点续扫的临时缓存(不要上传,exam_predictions.json 才是公开产物)
tools/exam_prediction/cache_daily.jsonl
/release-snapshots/
/downloads/
/beta_release/
*.html
*.csv
!tools/exam_prediction/output_*.csv

# ── git 重写历史时的临时备份目录 ──────────────────────
.git.backup-*/

# ── 截图与导出 ────────────────────────────────────────────
*.png
tools/_cap*.png
