<?xml version="1.0" encoding="utf-8"?>
<!--
    安大域名 (*.ahu.edu.cn) 默认 cleartextTrafficPermitted=false (API ≥28),
    但部分端点会返回 302 → http://,OkHttp 默认 followSslRedirects=true 会跟过去,
    然后被 NetworkSecurityPolicy 拦截抛 "CLEARTEXT communication to ... not permitted"。

    单域开 cleartext 白名单,其它域名维持默认严格策略:
      - adwmh.ahu.edu.cn   智慧安大支付码 (2026-06-22)
      - welearn.sflep.com  WeLearn 随行课堂 prelogin 302 跳链 (2026-06-28)
      - sso.sflep.com      WeLearn OIDC 登录 (同链)

    其它安大子域名 (one/ycard/jw/kqcard) 一直用 HTTPS,不需要 cleartext。
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">adwmh.ahu.edu.cn</domain>
    </domain-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">welearn.sflep.com</domain>
        <domain includeSubdomains="false">sso.sflep.com</domain>
    </domain-config>
</network-security-config>