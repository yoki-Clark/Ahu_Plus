<?xml version="1.0" encoding="utf-8"?>
<paths>
    <!-- 供 FileProvider 分享 Download 目录下的 APK 文件 -->
    <external-path
        name="downloads"
        path="Download/" />
    <!-- 应用私有 files 目录下的 Download（Android/data/.../files/Download） -->
    <external-files-path
        name="app_downloads"
        path="Download/" />
    <!-- 外部应用私有存储不可用时，UpdateManager 回退到 files/downloads。 -->
    <files-path
        name="internal_updates"
        path="downloads/" />
    <!-- 2026-06-22: 分享安装包缓存目录 -->
    <cache-path
        name="apk_share"
        path="apk_share/" />
    <!-- 开发者中心生成的脱敏诊断报告 -->
    <cache-path
        name="developer_reports"
        path="developer_reports/" />
</paths>
